# ──────────────────────────────────────────────────────────────
# packages/frontend env (template)
# Copy to .env.local. The frontend uses ONLY anon-level credentials.
# ──────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (PostgREST + RLS gated). Safe to ship to the browser
# because every demo-readable row is gated by `is_demo = true`.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
