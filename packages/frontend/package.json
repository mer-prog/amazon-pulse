    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.19",
    "happy-dom": "^14.12.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
