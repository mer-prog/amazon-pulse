{
  "name": "@amazon-pulse/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js 15 + React 19 dashboard for the amazon-pulse SP-API pipeline (sandbox demo)",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "build:cf": "npx @cloudflare/next-on-pages@1",
    "preview:cf": "npx wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "start": "next start --port 3000",
    "lint": "next lint --dir app --dir components --dir lib",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.12.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "happy-dom": "^14.12.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vercel": "^39.1.0",
    "vitest": "^1.6.0",
    "wrangler": "^3.78.0"
  }
}
