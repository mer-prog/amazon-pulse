# ──────────────────────────────────────────────────────────────
# amazon-pulse environment variables (template)
# Copy to .env.local and fill in actual values. Do NOT commit .env.local.
# ──────────────────────────────────────────────────────────────

# ── Amazon SP-API (Sandbox) ────────────────────────────────────
# Issued via Solution Provider Portal → "Add new app client"
SP_API_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SP_API_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SP_API_REFRESH_TOKEN=Atzr|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SP_API_APP_ID=amzn1.sp.solution.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Endpoint (sandbox-first; do NOT switch to production in this phase)
SP_API_ENDPOINT=https://sandbox.sellingpartnerapi-eu.amazon.com
SP_API_LWA_ENDPOINT=https://api.amazon.com/auth/o2/token

# Default region / marketplace (EU)
SP_API_REGION=eu-west-1

# Comma-separated marketplace IDs to sync. Phase 1 default: UK only.
# Full EU-region marketplace ID reference (Amazon-issued, public):
#   UK = A1F83G8C2ARO7P    DE = A1PA6795UKMFR9   FR = A13V1IB3VIYZZH
#   IT = APJ6JRA9NG5V4     ES = A1RKKUPIHCS9HS   NL = A1805IZSGTT6HS
#   BE = AMEN7PMS3EDWL     IE = A28R8C7NBKEWEA   SE = A2NODRKZP88ZB9
#   PL = A1C3SOZRARQ6R3    TR = A33AVAJ2PDY3EV   EG = ARBP9OOSHTCHU
#   SA = A17E79C6D8DWNP    AE = A2VIGQ35RCS4UG
SP_API_MARKETPLACE_IDS=A1F83G8C2ARO7P

# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_DB_PASSWORD=replace-with-strong-password

# ── Encryption (for storing SP-API refresh tokens at rest) ─────
# 32 bytes, base64-encoded. Generate via: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-base64-32byte-key

# ── Cloudflare Workers (filled in via wrangler secret) ─────────
# Leave blank locally; configured per-environment in wrangler.toml or via
# `wrangler secret put <NAME>` for production.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── Runtime ────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
